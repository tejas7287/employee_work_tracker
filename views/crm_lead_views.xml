<odoo>

    <!-- FULL CRM FORM VIEW -->
    <record id="crm_lead_form_inherit_task" model="ir.ui.view">
        <field name="name">crm.lead.form.task.reference</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_lead_view_form"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='partner_id']" position="after">

                <field name="task_ids"
                       string="Task Reference"
                       widget="many2many_tags"
                       options="{'no_create': True}"/>

            </xpath>

            <xpath expr="//div[@name='button_box']" position="inside">

                <button name="action_view_tasks"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-tasks"
                        invisible="task_count == 0">

                    <field name="task_count"
                           widget="statinfo"
                           string="Tasks"/>

                </button>

            </xpath>

        </field>
    </record>


    <!-- QUICK CREATE VIEW (KANBAN POPUP) -->
    <record id="crm_quick_create_task_reference" model="ir.ui.view">
        <field name="name">crm.quick.create.task.reference</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.quick_create_opportunity_form"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='partner_name']" position="after">

                <field name="task_ids"
                       widget="many2many_tags"
                       string="Task Reference"
                       options="{'no_create': True}"/>

            </xpath>

        </field>
    </record>

</odoo>