<odoo>

    <!-- TREE VIEW -->
    <record id="view_subtask_tree" model="ir.ui.view">
        <field name="name">employee.work.subtask.tree</field>
        <field name="model">employee.work.subtask</field>
        <field name="arch" type="xml">

            <list>
                <field name="name"/>
                <field name="task_id"/>
                <field name="employee_id"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="hours_spent"/>
                <field name="state"/>
            </list>

        </field>
    </record>


    <!-- FORM VIEW -->
    <record id="view_subtask_form" model="ir.ui.view">
        <field name="name">employee.work.subtask.form</field>
        <field name="model">employee.work.subtask</field>
        <field name="arch" type="xml">

            <form string="Subtask">

                <header>

                    <button name="action_send_for_approval"
                            string="Send For Approval"
                            type="object"
                            class="btn-primary"
                            />

                    <field name="state"
                           widget="statusbar"
                           statusbar_visible="draft,waiting,approved,rejected"/>

                </header>

                <sheet>

                    <group>
                        <field name="name"/>
                        <field name="task_id"/>
                        <field name="employee_id"/>
                    </group>

                    <group string="Timeline">
                        <field name="start_date"/>
                        <field name="end_date"/>
                    </group>

                    <group string="Work Details">
                        <field name="hours_spent"/>
                    </group>

                </sheet>

            </form>

        </field>
    </record>


    <!-- ACTION -->
    <record id="action_subtasks" model="ir.actions.act_window">
        <field name="name">Subtasks</field>
        <field name="res_model">employee.work.subtask</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>