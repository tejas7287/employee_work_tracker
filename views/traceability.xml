<odoo>
    <template id="traceability_template">
        <t t-call="web.html_container">
            <div style="padding:20px; font-family:Arial;">

                <!-- PRODUCT DETAILS -->
                <h2>Product: <t t-esc="product"/></h2>
                <h3>Serial: <t t-esc="serial"/></h3>
                <h4>Manufactured Date: <t t-esc="manufactured_date"/></h4>
                <h4>Total Cost: <t t-esc="cost"/></h4>
                <h4>Sales Price: <t t-esc="sales_price"/></h4>

                <br/>

                <!-- COMPONENT TABLE -->
                <h3>Components:</h3>

                <table border="1" style="width:100%; border-collapse:collapse; text-align:left;">
                    <thead style="background-color:#f2f2f2;">
                        <tr>
                            <th style="padding:8px;">Component</th>
                            <th style="padding:8px;">Serial</th>
                            <th style="padding:8px;">Vendor</th>
                            <th style="padding:8px;">Purchase Date</th>
                            <th style="padding:8px;">Cost</th>
                            <th style="padding:8px;">Sales Price</th>
                        </tr>
                    </thead>

                    <tbody>
                        <t t-if="components">
                            <t t-foreach="components" t-as="c">
                                <tr>
                                    <td style="padding:8px;">
                                        <t t-esc="c['name']"/>
                                    </td>
                                    <td style="padding:8px;">
                                        <t t-esc="c['serial']"/>
                                    </td>
                                    <td style="padding:8px;">
                                        <t t-esc="c['vendor']"/>
                                    </td>
                                    <td style="padding:8px;">
                                        <t t-esc="c.get('purchase_date', '')"/>
                                    </td>
                                    <td style="padding:8px;">
                                        <t t-esc="c['cost']"/>
                                    </td>
                                    <td style="padding:8px;">
                                        <t t-esc="c['sales_price']"/>
                                    </td>
                                </tr>
                            </t>
                        </t>

                        <!-- EMPTY STATE -->
                        <t t-if="not components">
                            <tr>
                                <td colspan="6" style="padding:10px; text-align:center;">
                                    No components found
                                </td>
                            </tr>
                        </t>
                    </tbody>
                </table>

            </div>
        </t>
    </template>
</odoo>