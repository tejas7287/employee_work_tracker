<odoo>

    <!-- LIST -->

    <record id="view_task_document_list" model="ir.ui.view">
        <field name="name">task.document.list</field>
        <field name="model">task.document</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="document_file" filename="file_name"/>
                <field name="file_name"/>
            </list>
        </field>
    </record>


    <!-- FORM -->

    <record id="view_task_document_form" model="ir.ui.view">
        <field name="name">task.document.form</field>
        <field name="model">task.document</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="document_file" filename="file_name"/>
                        <field name="file_name"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

</odoo>