<odoo>

    <!-- TREE VIEW -->
    <record id="view_task_tree" model="ir.ui.view">
        <field name="name">employee.work.task.tree</field>
        <field name="model">employee.work.task</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="employee_id"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="state"/>
                <field name="hours_spent"/>
            </list>
        </field>
    </record>
    <!-- KANBAN VIEW -->
    <record id="view_task_kanban" model="ir.ui.view">
        <field name="name">employee.work.task.kanban</field>
        <field name="model">employee.work.task</field>
        <field name="arch" type="xml">

            <kanban>

                <templates>

                    <t t-name="card">

                        <div class="oe_kanban_global_click">

                            <strong>
                                <field name="name"/>
                            </strong>

                            <div>
                                Employee :
                                <field name="employee_id"/>
                            </div>

                            <div>
                                State :
                                <field name="state"/>
                            </div>

                            <div>
                                Hours :
                                <field name="hours_spent"/>
                            </div>

                        </div>

                    </t>

                </templates>

            </kanban>

        </field>
    </record>


    <!-- GRAPH VIEW -->
    <record id="view_task_graph" model="ir.ui.view">
        <field name="name">employee.work.task.graph</field>
        <field name="model">employee.work.task</field>
        <field name="arch" type="xml">

            <graph string="Task Analysis" type="bar">

                <field name="employee_id" type="row"/>
                <field name="hours_spent" type="measure"/>

            </graph>

        </field>
    </record>


    <!-- PIVOT VIEW -->
    <record id="view_task_pivot" model="ir.ui.view">
        <field name="name">employee.work.task.pivot</field>
        <field name="model">employee.work.task</field>
        <field name="arch" type="xml">

            <pivot>

                <field name="employee_id" type="row"/>
                <field name="state" type="col"/>
                <field name="hours_spent" type="measure"/>

            </pivot>

        </field>
    </record>


    <!-- CALENDAR VIEW -->
    <record id="view_task_calendar" model="ir.ui.view">
        <field name="name">employee.work.task.calendar</field>
        <field name="model">employee.work.task</field>
        <field name="arch" type="xml">

            <calendar string="Task Calendar"
                      date_start="start_date"
                      date_stop="end_date">

                <field name="name"/>
                <field name="employee_id"/>

            </calendar>

        </field>
    </record>
    <record id="action_reset_to_draft" model="ir.actions.server">
        <field name="name">Reset to Draft</field>
        <field name="model_id" ref="model_employee_work_task"/>
        <field name="state">code</field>
        <field name="code"><![CDATA[
record.write({'state': 'draft'})
action = {
    "type": "ir.actions.client",
    "tag": "reload",
}
    ]]></field>
    </record>
    <!-- FORM VIEW -->
    <record id="view_task_form" model="ir.ui.view">

        <field name="name">employee.work.task.form</field>
        <field name="model">employee.work.task</field>
        <field name="arch" type="xml">

            <form>

                <!-- HEADER BUTTONS -->
                <header>

                    <button name="action_print_task_report"
                            string="Print Task"
                            type="object"
                            class="btn-primary"
                            display="always"/>

                    <button name="action_approve"
                            string="Approve"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'draft'"/>

                    <button name="action_reject"
                            string="Reject"
                            type="object"
                            class="btn-danger"
                            invisible="state != 'draft'"/>

                    <button name="%(employee_work_tracker.action_reset_to_draft)d"
                            string="Reset"
                            type="action"
                            class="btn-warning"
                            invisible="state == 'draft'"/>

                    <field name="state"
                           widget="statusbar"
                           options="{'clickable':'1'}"
                           statusbar_visible="draft,approved,rejected"/>

                </header>


                <sheet>

                    <!-- SMART MASTER BUTTON (like Project module) -->
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_products"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-cube">

                            <field name="product_count"
                                   widget="statinfo"
                                   string="Products"/>

                        </button>
                        <!-- SALES -->
                        <button name="action_view_sales"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-shopping-cart"
                                groups="sales_team.group_sale_salesman">
                            <field name="sale_count"
                                   widget="statinfo"
                                   string="Sales"/>
                        </button>

                        <!-- PURCHASE -->
                        <button name="action_view_purchase"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-truck"
                                groups="purchase.group_purchase_user">
                            <field name="purchase_count"
                                   widget="statinfo"
                                   string="Purchase"/>
                        </button>

                        <!-- MANUFACTURING -->
                        <button name="action_view_mrp"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-industry"
                                groups="mrp.group_mrp_user">
                            <field name="mrp_count"
                                   widget="statinfo"
                                   string="Manufacturing"/>
                        </button>

                        <!-- CRM -->
                        <button name="action_view_crm"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-user"
                                groups="sales_team.group_sale_salesman">
                            <field name="crm_count"
                                   widget="statinfo"
                                   string="CRM"/>
                        </button>


                        <button name="action_view_subtasks" type="object" class="oe_stat_button">
                            <field name="subtask_count" widget="statinfo" string="Subtasks"/>
                        </button>
                        <button name="action_view_documents"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-file">

                            <field name="document_count"
                                   widget="statinfo"
                                   string="Documents"/>

                        </button>


                    </div>


                    <!-- TASK INFORMATION -->

                    <group string="Task Information">

                        <field name="reference" readonly="1"/>

                        <field name="name"/>

                        <field name="department_id"/>
                        <field name="employee_ids"
                               widget="many2many_tags"
                               domain="[('id','in',allowed_employee_ids)]"/>

                        <field name="description"/>

                    </group>

                    <!-- TIMELINE -->
                    <group string="Timeline">
                        <field name="start_date"/>
                        <field name="end_date"/>
                    </group>


                    <!-- WORK DETAILS -->
                    <group string="Work Details">
                        <field name="hours_spent"/>
                        <field name="manager_id"/>

                        <field name="password"
                               groups="employee_work_tracker.group_work_manager,employee_work_tracker.group_work_admin"/>
                    </group>
                    <notebook>

                        <!-- PAGE 1 -->
                        <page string="Task Information" invisible="1">

                            <group>
                                <field name="name"/>
                                <field name="employee_id"/>
                                <field name="description"/>
                            </group>

                        </page>


                        <!-- PAGE 2 -->
                        <page string="Timeline" invisible="1">

                            <group>
                                <field name="start_date"/>
                                <field name="end_date"/>
                            </group>

                        </page>


                        <!-- PAGE 3 -->
                        <page string="Work Details" invisible="1">

                            <group>
                                <field name="hours_spent"/>
                                <field name="manager_id"/>

                                <field name="password"
                                       password="True"
                                       groups="employee_work_tracker.group_work_manager,employee_work_tracker.group_work_admin"/>
                            </group>

                        </page>


                        <!-- PAGE 4 -->
                        <page string="Subtasks">

                            <field name="subtask_ids">

                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="employee_id"/>
                                    <field name="start_date"/>
                                    <field name="end_date"/>
                                    <field name="state"/>
                                </list>

                            </field>

                        </page>
                        <page string="Sales">

                            <group>
                                <field name="partner_id"/>
                                <field name="sale_order_id" readonly="1"/>
                            </group>

                            <group>
                                <button name="action_confirm_sale"
                                        string="Confirm Sale Order"
                                        type="object"
                                        class="btn-primary"
                                        invisible="not partner_id"/>
                            </group>

                            <field name="order_line_ids">
                                <list editable="bottom">
                                    <field name="product_id"/>
                                    <field name="quantity"/>
                                    <field name="price_unit"/>
                                </list>
                            </field>
                        </page>
                        <page string="Documents">

                            <field name="document_ids">

                                <list editable="bottom">
                                    <field name="document_file" filename="file_name" widget="binary"/>
                                    <field name="file_name"/>
                                    <field name="uploaded_by"/>
                                    <field name="upload_date"/>
                                </list>

                            </field>

                        </page>

                        <page string="QR Code">

                            <group>
                                <field name="qr_url" readonly="1"/>
                                <field name="qr_code" widget="image" class="oe_avatar"/>
                            </group>

                        </page>
                    </notebook>

                </sheet>
                <chatter/>

            </form>

        </field>
    </record>

</odoo>