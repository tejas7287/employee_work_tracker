<odoo>

    <!-- ========================= -->
    <!-- GROUPS -->
    <!-- ========================= -->

    <record id="group_work_employee" model="res.groups">
        <field name="name">Work Tracker Employee</field>
        <field name="implied_ids" eval="[(4, ref('mrp.group_mrp_user'))]"/>
    </record>

    <record id="group_work_manager" model="res.groups">
        <field name="name">Work Tracker Manager</field>
        <field name="implied_ids" eval="[(4, ref('mrp.group_mrp_manager'))]"/>
    </record>

    <record id="group_work_admin" model="res.groups">
        <field name="name">Work Tracker Administrator</field>
        <field name="implied_ids" eval="[(4, ref('base.group_system'))]"/>
    </record>

    <!-- ========================= -->
    <!-- WORKORDER RULE -->
    <!-- ========================= -->

    <record id="rule_workorder_employee" model="ir.rule">
        <field name="name">Workorder: Only allowed employees</field>
        <field name="model_id" ref="mrp.model_mrp_workorder"/>
        <field name="domain_force">
            [('workcenter_id.employee_ids.user_id', 'in', [user.id])]
        </field>
        <field name="groups" eval="[(4, ref('employee_work_tracker.group_work_employee'))]"/>
    </record>

    <!-- ========================= -->
    <!-- QUALITY CHECK RULE -->
    <!-- ========================= -->

    <record id="rule_quality_check_employee_only" model="ir.rule">
        <field name="name">Quality Check: Only assigned employees</field>
        <field name="model_id" ref="quality.model_quality_check"/>
        <field name="domain_force">
            [('workorder_id.workcenter_id.employee_ids.user_id', 'in', [user.id])]
        </field>
        <field name="groups" eval="[(4, ref('employee_work_tracker.group_work_employee'))]"/>
    </record>

</odoo>