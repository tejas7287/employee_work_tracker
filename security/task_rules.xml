<odoo>

    <!-- Employee: can only see their own tasks -->
    <record id="employee_task_rule" model="ir.rule">
        <field name="name">Employee Own Tasks</field>
        <field name="model_id" ref="model_employee_work_task"/>
        <field name="groups" eval="[(4, ref('employee_work_tracker.group_work_employee'))]"/>
        <field name="domain_force">
            [('employee_id','=',user.employee_id.id)]
        </field>
    </record>


    <!-- Manager: can see all tasks -->
    <record id="manager_task_rule" model="ir.rule">
        <field name="name">Manager All Tasks</field>
        <field name="model_id" ref="model_employee_work_task"/>
        <field name="groups" eval="[(4, ref('employee_work_tracker.group_work_manager'))]"/>
        <field name="domain_force">[(1,'=',1)]</field>
    </record>


    <!-- Admin / Internal Users: FULL ACCESS (IMPORTANT) -->
    <record id="admin_task_rule" model="ir.rule">
        <field name="name">Admin All Tasks</field>
        <field name="model_id" ref="model_employee_work_task"/>
        <field name="groups" eval="[(4, ref('base.group_system'))]"/>
        <field name="domain_force">[(1,'=',1)]</field>
    </record>


    <!-- Portal Users: allow visibility (if needed in portal) -->
    <record id="portal_task_rule" model="ir.rule">
        <field name="name">Portal Task Access</field>
        <field name="model_id" ref="model_employee_work_task"/>
        <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
        <field name="domain_force">[(1,'=',1)]</field>
    </record>

</odoo>