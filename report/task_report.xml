<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_task_report" model="ir.actions.report">
        <field name="name">Task Report</field>
        <field name="model">employee.work.task</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">employee_work_tracker.task_report_template</field>
        <field name="report_file">employee_work_tracker.task_report_template</field>

        <!-- Optional dynamic file name -->
        <field name="print_report_name">'Task - %s' % (object.name)</field>

        <!-- Attach report to the model -->
        <field name="binding_model_id" ref="model_employee_work_task"/>
        <field name="binding_type">report</field>

    </record>



    <template id="task_report_template">

        <t t-call="web.basic_layout">

            <div class="page">

                <h2>Task Report</h2>

                <t t-foreach="docs" t-as="task">

                    <table class="table table-bordered">

                        <tr>
                            <th>Task</th>
                            <td><span t-field="task.name"/></td>
                        </tr>

                        <tr>
                            <th>Employee</th>
                            <td><span t-field="task.employee_id"/></td>
                        </tr>

                        <tr>
                            <th>Manager</th>
                            <td><span t-field="task.manager_id"/></td>
                        </tr>

                        <tr>
                            <th>Start Date</th>
                            <td><span t-field="task.start_date"/></td>
                        </tr>

                        <tr>
                            <th>End Date</th>
                            <td><span t-field="task.end_date"/></td>
                        </tr>

                        <tr>
                            <th>Hours Spent</th>
                            <td><span t-field="task.hours_spent"/></td>
                        </tr>

                        <tr>
                            <th>Status</th>
                            <td><span t-field="task.state"/></td>
                        </tr>

                        <tr>
                            <th>Description</th>
                            <td><span t-field="task.description"/></td>
                        </tr>

                    </table>

                    <br/>

                </t>

            </div>

        </t>

    </template>

</odoo>